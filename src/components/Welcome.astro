---
import { getCollection } from 'astro:content';
import profile from '../assets/profile.jpeg';

// Get all blog posts sorted by date
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 2);

// Calculate category counts
const categories = Array.from(
  new Set(allPosts.flatMap(post => post.data.tags ?? ['misc']))
)
  .map(tag => ({
    name: tag,
    count: allPosts.filter(
      post => post.data.tags?.includes(tag) ?? tag === 'misc'
    ).length
  }))
  .sort((a, b) => b.count - a.count);

const getRelativeTime = (date: string | Date): string => {
  try {
    const now = new Date();
    const diffMs = now.getTime() - new Date(date).getTime();
    const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

    if (diffDays === 0) return 'Today';
    if (diffDays === 1) return 'Yesterday';
    if (diffDays < 7) return `${diffDays} days ago`;

    return new Intl.DateTimeFormat('en-US', {
      month: 'short',
      day: 'numeric'
    }).format(new Date(date));
  } catch {
    return 'Unknown date';
  }
};
---

<main class="py-20 text-gray-900 overflow-hidden">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Hero Section -->
    <section class="flex flex-col md:flex-row items-center gap-12 mb-32">
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-5xl md:text-6xl font-black tracking-tight mb-6">
          I'm <span class="text-indigo-600">Madan Belbase</span>
        </h1>
        <p class="text-xl text-gray-500 mb-10 leading-relaxed max-w-2xl">
          Engineering Student & Developer creating thoughtful digital experiences. Building for the web and documenting the journey here.
        </p>
        <div class="flex flex-wrap justify-center md:justify-start gap-4">
          <a href="/blog/" class="px-7 py-3 bg-gray-900 text-white rounded-xl font-bold hover:bg-indigo-600 transition-colors">
            Read Blog
          </a>
          <a href="/about/" class="px-7 py-3 bg-white text-gray-700 border border-gray-200 rounded-xl font-bold hover:bg-gray-50 transition-colors">
            About Me
          </a>
        </div>
      </div>
      <div class="w-48 h-48 md:w-64 md:h-64 flex-shrink-0">
        <img
          src={profile.src}
          alt="Madan Belbase"
          class="w-full h-full object-cover rounded-2xl border border-gray-100 shadow-sm"
        />
      </div>
    </section>

    <!-- Simple Content List -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      
      <!-- Latest Posts -->
      <div class="lg:col-span-8">
        <h2 class="text-xs font-black uppercase tracking-[0.2em] text-gray-400 mb-10 border-b border-gray-50 pb-4">
          Latest Postings
        </h2>
        
        <div class="space-y-12">
          {latestPosts.map(post => (
            <article class="group">
              <time class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 block">
                {getRelativeTime(post.data.pubDate)}
              </time>
              <h3 class="text-2xl font-bold text-gray-900 group-hover:text-indigo-600 transition-colors mb-3">
                <a href={`/blog/${post.slug}/`}>
                  {post.data.title}
                </a>
              </h3>
              <p class="text-gray-500 line-clamp-2 mb-4 leading-relaxed text-sm">
                {post.data.description}
              </p>
              <a href={`/blog/${post.slug}/`} class="text-xs font-black uppercase tracking-widest text-gray-900 flex items-center gap-1 hover:text-indigo-600 transition-colors">
                Full Article <span>→</span>
              </a>
            </article>
          ))}
        </div>
      </div>

      <!-- Interests -->
      <aside class="lg:col-span-4">
        <h2 class="text-xs font-black uppercase tracking-[0.2em] text-gray-400 mb-10 border-b border-gray-50 pb-4">
          Interests
        </h2>
        <div class="space-y-2">
          {categories.slice(0, 8).map(category => (
            <a
              href={`/blog/tag/${category.name.toLowerCase()}/`}
              class="flex justify-between items-center py-2 text-gray-600 hover:text-indigo-600 transition-colors border-b border-gray-50 last:border-0"
            >
              <span class="font-bold text-sm tracking-tight">{category.name}</span>
              <span class="text-[10px] font-bold text-gray-400 bg-gray-50 px-2 py-0.5 rounded-md">{category.count}</span>
            </a>
          ))}
        </div>
      </aside>

    </div>
  </div>
</main>
